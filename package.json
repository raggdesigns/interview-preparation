{
  "scripts": {
    "lint:md": "markdownlint-cli2 \"**/*.md\" \"#node_modules\"",
    "lint:md:fix": "node scripts/fix-md040.mjs && markdownlint-cli2 --fix \"**/*.md\" \"#node_modules\"",
    "lint:links": "find . -name '*.md' -not -path '*/node_modules/*' | xargs -n1 markdown-link-check -q"
  },
  "devDependencies": {
    "markdown-link-check": "^3.14.2",
    "markdownlint-cli2": "^0.21.0"
  }
}
